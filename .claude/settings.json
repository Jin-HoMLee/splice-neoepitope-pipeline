{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check_at_claude.py",
            "if": "Bash(gh *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/check_gh_issue_develop_parent.py",
            "if": "Bash(gh issue develop *)",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/check_board_query_pagination.py",
            "if": "Bash(gh api *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/check_parent_status_precondition.py",
            "if": "Bash(gh api *)",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post_gh_pr_create.py",
            "if": "Bash(gh *)",
            "timeout": 35
          },
          {
            "type": "command",
            "command": ".claude/hooks/recheck_dispatch.py --scope shared",
            "if": "Bash(gh *)",
            "timeout": 30
          }
        ]
      }
    ]
  }
}

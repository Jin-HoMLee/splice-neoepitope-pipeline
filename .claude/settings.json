{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/check_at_claude.py",
            "if": "Bash(gh *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/check_gh_issue_develop_parent.py",
            "if": "Bash(gh issue develop *)",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post_gh_pr_create.py",
            "if": "Bash(gh *)",
            "timeout": 35
          }
        ]
      }
    ]
  }
}
